# Required: colon-separated user:pass:role;user2:pass2:role2
# Roles: owner | admin | member
AUTH_CREDENTIALS="admin:sekret:owner;user1:pass1:member"

# Optional: Twilio Network Traversal Service for dynamic TURN credentials
# Get Account SID and Auth Token from https://console.twilio.com
# TWILIO_ACCOUNT_SID="your_account_sid"
# TWILIO_AUTH_TOKEN="your_auth_token"
# If unset, will fall back to Google STUN only (no TURN relay)

# Optional: ICE mode (stun-only | relay-only | normal, default: stun-only)
# ICE_MODE=normal

# Optional: restrict CORS (default: allow all)
# CORS_ORIGIN="https://your-app.onrender.com"

# Optional: enable debug logging
# DEBUG=true
